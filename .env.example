# =============================================================================
# LUMINA — Environment Variables
# Copy to .env and fill in values:  cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://lumina:lumina_dev@localhost:5432/lumina
POSTGRES_PASSWORD=lumina_dev

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Auth / Security ---------------------------------------------------------
JWT_SECRET=replace-with-a-strong-random-secret
CORS_ORIGINS=http://localhost:3000

# --- AI Provider Keys --------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...

# --- Knowledge Graph / Vector DB --------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
PINECONE_API_KEY=

# --- Notifications -----------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SENDGRID_API_KEY=SG....

# --- GCP Deployment ----------------------------------------------------------
GCP_PROJECT_ID=lumina-prod
GCP_REGION=us-central1

# --- Misc --------------------------------------------------------------------
LOG_LEVEL=info
